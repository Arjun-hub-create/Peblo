PORT=5000
# Windows + mongodb+srv: if connect fails with querySrv ECONNREFUSED, the server
# auto-uses 8.8.8.8 / 1.1.1.1 unless you set MONGO_DNS_USE_SYSTEM=1 or override:
# DNS_SERVERS=8.8.8.8,1.1.1.1
MONGODB_URI=YOUR_MONGODB_URI_HERE
JWT_SECRET=YOUR_JWT_SECRET_HERE
# OpenAI (sk-...) or OpenRouter (sk-or-v1-...) — OpenRouter auto-detected from key prefix
OPENAI_API_KEY=YOUR_API_KEY_HERE
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=openai/gpt-4o-mini
CLIENT_URL=http://localhost:5173
